# Local credentials and defaults for this repo.
# Do not commit real secrets. Export them in your shell or source a copied file.

# Prime / hosted RL
PRIME_ENV_OWNER=
PRIME_API_KEY=

# Weights & Biases
WANDB_API_KEY=
WANDB_PROJECT=mera
WANDB_ENTITY=
WANDB_RUN_NAME=
 
# Local prime-rl entrypoint (optional if `rl` is on PATH)
PRIME_RL_ENTRY=

# Hugging Face
HF_TOKEN=
# Alternative name also supported by huggingface_hub:
HUGGINGFACE_HUB_TOKEN=
HF_RL_REPO_ID=

# Optional eval endpoints
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Optional MERA dataset override
MERA_DATA_DIR=
