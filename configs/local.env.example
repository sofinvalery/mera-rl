# Local credentials and defaults for this repo.
# Do not commit real secrets. Export them in your shell or source a copied file.

# Prime / hosted RL
PRIME_ENV_OWNER=
PRIME_API_KEY=

# Weights & Biases
WANDB_API_KEY=
WANDB_PROJECT=mera        # used by SFT/hosted scripts; RLVR local uses TOML config
WANDB_ENTITY=             # optional (W&B SDK environment), not passed by RLVR launcher
WANDB_RUN_NAME=
 
# Local prime-rl entrypoint (optional if `rl` is on PATH)
PRIME_RL_ENTRY=
UV_PROJECT=

# RLVR launcher controls
MERA_RLVR_WANDB_MODE=offline       # auto|online|offline|disabled
MERA_RLVR_WANDB_OFFLINE_FALLBACK=1 # if online probe fails in auto/online, fallback to offline
MERA_RLVR_MODEL_REPO=sofinvalery/mera-qwen3-4b-sft
MERA_RLVR_MODEL_DIR=/workspace/models/mera-qwen3-4b-sft
MERA_RLVR_PREPULL_MODEL=1

# Hugging Face
HF_TOKEN=
# Alternative name also supported by huggingface_hub:
HUGGINGFACE_HUB_TOKEN=
HF_RL_REPO_ID=

# Optional eval endpoints
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Optional MERA dataset override
MERA_DATA_DIR=
